  <style>
    /* ── Experiences section ── */
    .experiences-home-section {
      padding: 110px 0;
      background: var(--tile-dark);
      position: relative;
      overflow: hidden;
    }
    .experiences-home-section::before {
      content: '';
      position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='rgba(200,169,110,0.05)' stroke-width='0.5'%3E%3Cpolygon points='30,4 56,18 56,42 30,56 4,42 4,18'/%3E%3Cpolygon points='30,14 46,23 46,37 30,46 14,37 14,23'/%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }
    .experiences-home-section::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(200,134,58,0.09) 0%, transparent 70%);
      pointer-events: none;
    }
    .experiences-home-section .container { position: relative; z-index: 1; }
    .experiences-home-section .services-header .section-eyebrow { color: var(--gold); }
    .experiences-home-section .services-header .section-eyebrow::before { background: var(--gold); }
    .experiences-home-section .services-header .section-eyebrow::after { background: var(--gold); }
    .experiences-home-section .services-header .section-title { color: var(--sand); }
    .experiences-home-section .services-header .section-title em { color: var(--gold-light); }

    .exp-home-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 24px;
      margin-bottom: 52px;
    }
    .exp-home-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(200,169,110,0.14);
      display: flex; flex-direction: column;
      overflow: hidden;
      transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease), border-color 0.3s, background 0.3s;
    }
    .exp-home-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 24px 56px rgba(0,0,0,0.4);
      border-color: rgba(200,134,58,0.35);
      background: rgba(255,255,255,0.06);
    }
    .exp-home-card-image { position: relative; height: 210px; overflow: hidden; }
    .exp-home-card-image img {
      width: 100%; height: 100%; object-fit: cover;
      transition: transform 0.55s var(--ease);
      filter: brightness(0.88);
    }
    .exp-home-card:hover .exp-home-card-image img { transform: scale(1.07); filter: brightness(1); }
    .exp-home-card-badge {
      position: absolute; top: 14px; left: 14px; z-index: 2;
      background: var(--ochre); color: var(--cream);
      font-size: 0.58rem; font-weight: 700;
      letter-spacing: 0.14em; text-transform: uppercase;
      padding: 5px 12px;
    }
    .exp-home-card-body {
      padding: 26px 24px;
      display: flex; flex-direction: column; flex: 1; gap: 10px;
    }
    .exp-home-card-location {
      font-size: 0.63rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--ochre);
    }
    .exp-home-card-title {
      font-family: var(--serif);
      font-size: 1.18rem; font-weight: 400;
      color: var(--sand); line-height: 1.3;
    }
    .exp-home-card-desc {
      font-size: 0.85rem; font-weight: 300;
      color: rgba(232,220,200,0.5);
      line-height: 1.7; flex: 1;
    }
    .exp-home-card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .exp-home-card-tags span {
      font-size: 0.63rem; font-weight: 500;
      letter-spacing: 0.08em;
      color: rgba(200,169,110,0.6);
      background: rgba(200,169,110,0.06);
      border: 1px solid rgba(200,169,110,0.14);
      padding: 4px 10px;
    }
    .exp-home-card-rating { font-size: 0.8rem; color: var(--gold); font-weight: 600; }
    .exp-home-card-rating span {
      color: rgba(200,169,110,0.4);
      font-weight: 300; font-size: 0.75rem; margin-left: 4px;
    }
    .exp-home-card-cta {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent;
      color: var(--gold-light) !important;
      border: 1px solid rgba(200,169,110,0.3);
      padding: 10px 20px;
      font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase;
      transition: all 0.35s var(--ease);
      align-self: flex-start;
    }
    .exp-home-card-cta:hover {
      background: var(--ochre); border-color: var(--ochre);
      color: var(--cream) !important; gap: 14px;
    }
    @media (max-width: 768px) {
      .exp-home-grid .exp-home-card:nth-child(n+5) { display: none; }
      .exp-home-grid { grid-template-columns: 1fr; }
    }
    .experiences-home-section .btn-secondary {
      color: var(--sand) !important;
      border-color: rgba(232,220,200,0.3);
    }
    .experiences-home-section .btn-secondary:hover {
      background: var(--ochre);
      color: var(--cream) !important;
      border-color: var(--ochre);
    }

    /* ── Journal grid ── */
    .journal-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 40px;
    }
    @media (max-width: 1024px) { .journal-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 768px) { .journal-grid { grid-template-columns: 1fr; } }

    /* ── THREE-TIER PRICING ── */
    .pricing-section-tiers { padding: 120px 0 80px; background: var(--cream); position: relative; }
    .pricing-header { text-align: center; margin-bottom: 64px; }
    .tier-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 24px;
      align-items: start;
      margin-bottom: 48px;
    }
    @media (max-width: 960px) {
      .tier-grid { grid-template-columns: 1fr; max-width: 480px; margin-left: auto; margin-right: auto; }
    }
    .tier-card {
      background: #fff;
      border: 1px solid var(--border);
      padding: 40px 32px 36px;
      position: relative;
      transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
    }
    .tier-card:hover { transform: translateY(-6px); box-shadow: 0 20px 56px rgba(30,48,64,0.10); }
    .tier-featured {
      background: var(--tile-dark);
      border-color: var(--ochre);
      transform: translateY(-12px);
      box-shadow: 0 24px 64px rgba(30,48,64,0.18);
      z-index: 2;
    }
    .tier-featured:hover { transform: translateY(-18px); box-shadow: 0 32px 72px rgba(30,48,64,0.24); }
    .tier-popular-badge {
      position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
      background: var(--ochre); color: #fff;
      font-family: var(--sans); font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.18em; text-transform: uppercase;
      padding: 6px 18px; white-space: nowrap;
    }
    .tier-label {
      font-family: var(--sans); font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--ochre); margin-bottom: 20px;
    }
    .tier-featured .tier-label { color: var(--gold); }
    .tier-price-wrap { margin-bottom: 24px; }
    .tier-price {
      font-family: var(--serif); font-size: 3.2rem; font-weight: 600;
      color: var(--tile); line-height: 1;
      display: flex; align-items: flex-start; gap: 2px;
    }
    .tier-featured .tier-price { color: var(--sand); }
    .tier-currency { font-size: 1.4rem; margin-top: 6px; font-weight: 400; }
    .tier-cents { font-size: 1.6rem; margin-top: 4px; font-weight: 300; }
    .tier-cadence { font-size: 0.72rem; color: var(--smoke); margin-top: 6px; letter-spacing: 0.04em; }
    .tier-featured .tier-cadence { color: rgba(232,220,200,0.45); }
    .tier-divider { height: 1px; background: var(--border); margin-bottom: 24px; }
    .tier-featured .tier-divider { background: rgba(200,169,110,0.2); }
    .tier-features {
      list-style: none; display: flex; flex-direction: column;
      gap: 11px; margin-bottom: 32px;
    }
    .tier-features li {
      font-size: 0.87rem; color: var(--ink);
      display: flex; align-items: flex-start; gap: 10px; line-height: 1.4;
    }
    .tier-featured .tier-features li { color: rgba(232,220,200,0.8); }
    .tier-featured .tier-features li strong { color: var(--sand); }
    .tier-check { color: var(--ochre); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .tier-check-gold { color: var(--gold); }
    .tier-check-vip { color: #e2c990; }
    .tier-feature-missing { opacity: 0.35; }
    .tier-x { color: var(--smoke); flex-shrink: 0; }
    .tier-btn {
      display: block; width: 100%; text-align: center;
      font-family: var(--sans); font-size: 0.72rem; font-weight: 700;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 15px 24px;
      transition: all 0.35s var(--ease);
      position: relative; margin-bottom: 16px;
    }
    .tier-btn-basic {
      background: transparent; border: 1px solid rgba(30,48,64,0.25); color: var(--tile);
    }
    .tier-btn-basic:hover { background: var(--tile); color: var(--cream); border-color: var(--tile); }
    .tier-btn-complete {
      background: var(--ochre); color: #fff !important;
      border: 1px solid var(--ochre); padding: 17px 24px;
    }
    .tier-btn-complete:hover { background: var(--ochre-deep); border-color: var(--ochre-deep); }
    .tier-btn-badge {
      position: absolute; top: -10px; right: 16px;
      background: var(--gold); color: var(--tile-dark);
      font-size: 0.55rem; font-weight: 800; letter-spacing: 0.1em; padding: 3px 8px;
    }
    .tier-btn-vip {
      background: transparent; border: 1px solid var(--gold); color: var(--tile);
    }
    .tier-btn-vip:hover { background: var(--gold); color: var(--tile-dark); }
    .tier-vip { border-color: rgba(200,169,110,0.35); }
    .tier-note { font-size: 0.72rem; color: var(--smoke); text-align: center; line-height: 1.5; }
    .tier-featured .tier-note { color: rgba(232,220,200,0.35); }
    .tier-trust {
      display: flex; justify-content: center; flex-wrap: wrap;
      gap: 24px; font-size: 0.75rem; font-weight: 500;
      letter-spacing: 0.06em; color: var(--smoke); margin-bottom: 24px;
    }
    .tier-payment { display: flex; justify-content: center; }
    .tier-payment img { max-width: 280px; opacity: 0.6; }
  </style>
</head>
