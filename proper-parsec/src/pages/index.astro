---
const postFiles = import.meta.glob('./blog/*.mdx', { eager: true });
const posts = Object.values(postFiles)
  .sort((a: any, b: any) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime())
  .slice(0, 3);
---

