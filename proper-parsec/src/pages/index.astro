<script is:inline src="/translations.js"></script>
<script is:inline>
  const mobileNavStyle = document.createElement('style');
  mobileNavStyle.textContent = `
    .nav-center-stack {
      display: flex; flex-direction: row; align-items: center;
      gap: 14px; position: static; transform: none;
    }
    @media (max-width: 768px) {
      .nav-container {
        display: flex; flex-direction: row; align-items: center;
        height: 68px; min-height: 68px; padding: 0 16px; position: relative;
      }
      .nav-logo { flex-shrink: 0; }
      .nav-right {
        display: flex; flex-direction: row; align-items: center;
        margin-left: auto; flex-shrink: 0; gap: 8px;
      }
      .nav-center-stack {
        position: absolute; left: 50%; transform: translateX(-50%);
        display: flex; flex-direction: column; align-items: center; gap: 4px;
      }
      .language-switcher { display: flex; gap: 3px; }
      .lang-btn { font-size: 0.58rem; padding: 2px 5px; }
      .nav-cta { font-size: 0.58rem; padding: 5px 10px; white-space: nowrap; }
      .hamburger { flex-shrink: 0; margin-left: 4px; }
    }
  `;
  document.head.appendChild(mobileNavStyle);

  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });

  const hamburger = document.getElementById('hamburger');
  const drawer    = document.getElementById('mobile-drawer');
  hamburger.addEventListener('click', () => {
    const open = drawer.classList.toggle('open');
    hamburger.classList.toggle('open', open);
    hamburger.setAttribute('aria-expanded', open);
  });
  function closeDrawer() {
    drawer.classList.remove('open');
    hamburger.classList.remove('open');
    hamburger.setAttribute('aria-expanded', false);
  }
  document.addEventListener('click', (e) => {
    if (!nav.contains(e.target)) closeDrawer();
  });

  document.querySelectorAll('.book-thumb').forEach(thumb => {
    thumb.addEventListener('click', () => {
      document.querySelectorAll('.book-thumb').forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
      const cover = document.getElementById('main-book-cover');
      cover.style.opacity = '0';
      setTimeout(() => {
        cover.src = thumb.dataset.cover;
        cover.style.opacity = '1';
      }, 200);
    });
  });
  document.getElementById('main-book-cover').style.transition = 'opacity 0.3s ease';

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('in'); observer.unobserve(e.target); }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
// Smooth scroll all go-to-pricing buttons to #pricing section
document.querySelectorAll('.go-to-pricing').forEach(btn => {
  btn.addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('pricing').scrollIntoView({ behavior: 'smooth' });
  });
});
</script>

